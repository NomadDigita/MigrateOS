# Application runtime
MIGRATEOS_ENVIRONMENT=development
MIGRATEOS_LOG_LEVEL=INFO
MIGRATEOS_DATABASE_URL=postgresql+psycopg://migrateos:migrateos@postgres:5432/migrateos
MIGRATEOS_REDIS_URL=redis://redis:6379/0
MIGRATEOS_CORS_ORIGINS=http://localhost:3000

# Development-only authentication. Set a non-empty value locally before using /api/v1/auth/me.
MIGRATEOS_DEV_AUTH_TOKEN=

# Server/worker-only OpenAI configuration. Never expose it to the frontend.
MIGRATEOS_OPENAI_MODEL=

# Frontend API origin
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000/api/v1
