# Application runtime
MIGRATEOS_ENVIRONMENT=development
MIGRATEOS_LOG_LEVEL=INFO
MIGRATEOS_DATABASE_URL=postgresql+psycopg://migrateos:migrateos@postgres:5432/migrateos
MIGRATEOS_REDIS_URL=redis://redis:6379/0
MIGRATEOS_CORS_ORIGINS=http://localhost:3000

# Development-only authentication. Set a non-empty value locally before using /api/v1/auth/me.
MIGRATEOS_DEV_AUTH_TOKEN=

# Server/worker-only OpenAI configuration. Never expose it to the frontend.
MIGRATEOS_OPENAI_MODEL=
# Use the Supabase PostgreSQL connection string for MIGRATEOS_DATABASE_URL in hosted environments.
# The API persists through SQLAlchemy/Alembic; no Supabase service-role key is exposed or required.
# Optional server-side workspace used for single-tenant onboarding. Never expose it in the browser.
MIGRATEOS_DEFAULT_PROJECT_ID=
# `background` works without Redis. Set `celery` only when the worker and Redis are deployed.
MIGRATEOS_WORKFLOW_DISPATCH=background

# Frontend API origin
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000/api/v1
